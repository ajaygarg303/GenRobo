# Copy to backend/.env for local API, or set in docker-compose / ECS task definition

# Database: SQLite (default) or PostgreSQL (e.g. Amazon RDS)
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME?ssl=require

# Session
SESSION_IDLE_TIMEOUT_MINUTES=30

# OpenAI API (optional — leave OPENAI_API_KEY blank to use mock replies)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# Optional: send transcript emails (otherwise logged to stdout)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Frontend dev only: leave empty when UI and API share the same origin
# VITE_API_BASE=http://127.0.0.1:8000

# API docs at /docs (disable in production image via ENABLE_DOCS=false)
ENABLE_DOCS=true

# Comma-separated browser origins for CORS when UI is hosted separately
# CORS_ORIGINS=https://your-alb.amazonaws.com

# Shared S3 bucket for tenant KB files; per-tenant object key is stored in RDS (tenants.knowledge_s3_key)
# KNOWLEDGE_S3_BUCKET=your-company-kb-bucket

# Optional Redis for KB text cache (default TTL 30 minutes)
# REDIS_URL=redis://localhost:6379/0
# KB_CACHE_TTL_SECONDS=1800

# Copy to backend/.env for local API, or set in docker-compose / ECS task definition

# Database: SQLite (local default) or PostgreSQL (required on ECS/RDS)
# Local:
# DATABASE_URL=sqlite+aiosqlite:///./data/app.db
# AWS RDS (set on ECS task — same DB where you inserted tenants):
# Use postgresql+asyncpg:// (postgresql:// is auto-converted on startup)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@database-1.xxxxx.eu-west-1.rds.amazonaws.com:5432/postgres?ssl=require
# If password has @ # / % etc., URL-encode it (e.g. @ → %40)

# Session
SESSION_IDLE_TIMEOUT_MINUTES=30

# OpenAI API (optional — leave OPENAI_API_KEY blank to use mock replies)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# Optional: send transcript emails (otherwise logged to stdout)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Avoid hanging ECS tasks if SMTP is unreachable (default 15)
SMTP_TIMEOUT_SECONDS=15

# Frontend dev only: leave empty when UI and API share the same origin
# VITE_API_BASE=http://127.0.0.1:8000

# Multi-tenant hostnames: {tenant_slug}.myrobochat.com (set at Docker/npm build time)
# VITE_TENANT_BASE_DOMAIN=myrobochat.com

# API docs at /docs (disable in production image via ENABLE_DOCS=false)
ENABLE_DOCS=true

# Comma-separated browser origins for CORS when UI is hosted separately
# CORS_ORIGINS=https://your-alb.amazonaws.com

# Shared S3 bucket for tenant KB files; per-tenant object key is stored in RDS (tenants.knowledge_s3_key)
# KNOWLEDGE_S3_BUCKET=your-company-kb-bucket

# Optional Redis for KB text cache (default TTL 30 minutes)
# REDIS_URL=redis://localhost:6379/0
# KB_CACHE_TTL_SECONDS=1800

# In-chat idle reminder (seconds) then auto-close after another period
CHAT_IDLE_REMINDER_SECONDS=30
CHAT_IDLE_END_AFTER_REMINDER_SECONDS=30
# CHAT_IDLE_REMINDER_MESSAGE=Are you still there? Send a message to keep this chat open.
